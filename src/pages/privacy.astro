---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Privacy Policy | classactionsettlementcalc.com';
const description = 'Privacy policy for classactionsettlementcalc.com — how we collect, use, and protect visitor data, including Google AdSense and Google Analytics.';
---
<BaseLayout title={title} description={description}>
  <h1>Privacy Policy</h1>
  <p><strong>Effective date:</strong> January 1, 2026. Last reviewed: May 2026.</p>
  <p>classactionsettlementcalc.com does not collect personal information directly from visitors. This policy explains what data is collected through third-party services and what choices you have.</p>

  <h2>Who We Are</h2>
  <p>classactionsettlementcalc.com is operated by The Click Lab (business email: <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>).</p>

  <h2>Information We Collect</h2>
  <p>We do not operate account registration, contact forms, or email lists. Data collection occurs only through:</p>
  <ul>
    <li><strong>Google AdSense:</strong> Displays advertising. Google collects usage data, device information, and IP address to serve relevant ads, governed by Google&rsquo;s Privacy Policy at <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">policies.google.com/privacy</a>.</li>
    <li><strong>Google Analytics 4:</strong> Aggregate traffic data (page views, session duration, device type). No personally identifiable information is collected.</li>
  </ul>
  <p>All calculator inputs are processed in your browser using JavaScript. No settlement amounts, class size estimates, or claims rate inputs are transmitted to our servers or to any third party.</p>

  <h2>Cookies</h2>
  <p>We do not set first-party cookies. Opt out of personalized advertising at <a href="https://adssettings.google.com" target="_blank" rel="noopener noreferrer">adssettings.google.com</a>.</p>

  <h2>Data Sharing</h2>
  <p>We do not sell or share visitor data with third parties beyond Google as described above.</p>

  <h2>Children&rsquo;s Privacy</h2>
  <p>This site is not directed at children under 13.</p>

  <h2>Contact</h2>
  <p>Questions? Email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>

  <p>Return to the <a href="/">calculator</a> or see the <a href="/terms/">terms of use</a>.</p>
</BaseLayout>
